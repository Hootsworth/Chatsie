# =========================================================================
# Video Conferencing Platform (Zoom/Meet Clone) Environment Configuration
# Copy this file to `.env.local` (for frontend) and `.env` (for backend)
# =========================================================================

# -------------------------------------------------------------------------
# 1. SUPABASE DATABASE CONFIGURATION (Required for both Frontend and Backend)
# -------------------------------------------------------------------------
# Get these values from your Supabase Project Settings > API
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Backend-only: Service role key to bypass RLS in serverless functions
# WARNING: Keep this secret and NEVER commit it or expose it in frontend
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-private-key

# -------------------------------------------------------------------------
# 2. REALTIME SIGNALING CONFIGURATION
# -------------------------------------------------------------------------
# Provider options: 'supabase' (serverless, zero-setup) or 'socketio' (Node backend)
VITE_SIGNALING_PROVIDER=supabase

# Required ONLY if VITE_SIGNALING_PROVIDER is set to 'socketio'
# URL of the Express/Socket.IO server running locally or deployed (e.g., Render/Railway)
VITE_SIGNALING_SERVER_URL=http://localhost:5001

# -------------------------------------------------------------------------
# 3. BACKEND API ENDPOINTS
# -------------------------------------------------------------------------
# URL of your Vercel Serverless backend API. Keep empty in production
# if both frontend and backend are hosted under the same Vercel deployment project.
VITE_API_URL=http://localhost:3000

# -------------------------------------------------------------------------
# 4. TURN/STUN SERVER Ephemeral Credentials (Optional - Production Only)
# -------------------------------------------------------------------------
# To bypass restricted NATs, configure Twilio's Network Traversal Service
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Or supply static TURN configuration:
STATIC_TURN_URL=turn:your-turn-server.com:3478
STATIC_TURN_USERNAME=
STATIC_TURN_CREDENTIAL=

# -------------------------------------------------------------------------
# 5. NODE SERVER PORT
# -------------------------------------------------------------------------
# Required only for running Socket.IO backend locally
PORT=5001
